<?php
// Copier ce fichier vers app/config.php et renseigner les valeurs.
// Ne JAMAIS committer app/config.php (cf. .gitignore).

declare(strict_types=1);

// URL publique (sans slash final).
const BASE_URL    = '';                              // ex: 'https://creneaux.mon-asso.org'

// Dossier runtime (hors docroot, writable par le user PHP).
const DATA_DIR    = '';                              // ex: __DIR__ . '/../data'

// Chemin absolu vers le fichier SQLite. Dérivé de DATA_DIR par défaut.
const DB_PATH     = DATA_DIR . '/creneaux.sqlite';

// Secret HMAC pour le CSRF, 64 caractères hexadécimaux.
// Générer : php -r "echo bin2hex(random_bytes(32));"
const SECRET_CSRF = '';

// Expéditeur des mails (notifications d'annulation de créneau, phase ultérieure).
const MAIL_FROM   = '';                              // ex: 'contact@mon-asso.org'

// Flux SSE en plus du polling htmx (off par défaut : polling 30 s suffit).
const SSE_ENABLED = false;

// Webhook Discord pour être prévenu des modifications dans les réglages.
// Vide = désactivé. Créer via Paramètres du salon → Intégrations → Webhooks.
const DISCORD_WEBHOOK_URL = '';

// Notification de mise à jour : au chargement de /reglages, l'app interroge
// (au plus une fois par 24 h) l'API publique GitHub pour savoir si une release
// plus récente existe, et affiche un bandeau le cas échéant. Aucune écriture
// sur le code, fail-open (GitHub injoignable = pas de bandeau). Le seul appel
// sortant est un GET vers api.github.com avec un User-Agent générique.
// Mettre false pour le désactiver complètement.
const MAJ_CHECK = true;

// Mot de passe admin (hash) pour protéger les routes de configuration :
// /reglages, modification/suppression de créneau, gestion des modèles,
// étiquettes, fermetures, bandeau d'accueil, identité de l'asso.
// Vide = aucune protection — n'importe quelle visite peut tout effacer.
// FORTEMENT recommandé en prod publique. Générer le hash :
//   php -r "echo password_hash('mot-de-passe-clair', PASSWORD_DEFAULT);"
const ADMIN_PASSWORD_HASH = '';

// --- Customisation d'instance (surchargeable sans toucher au repo public) ---
// Ces valeurs sont les DÉFAUTS affichés tant que l'admin n'a rien réglé via
// /reglages. Une fois un réglage posé dans la carte « Identité de l'asso »,
// la DB prend le pas. Surcharger ici pour éviter d'avoir à cliquer après
// chaque install ; ce fichier n'est pas commité (voir .gitignore), donc tes
// valeurs d'asso ne partent pas dans le repo public.
const ASSO_NOM_DEFAUT      = 'Mon asso';             // ex: 'Le MUR XXe'
const ASSO_LOGO_URL_DEFAUT = '';                     // URL publique http/https, vide = pas de logo

// Fuseau horaire (affecte la génération automatique des mois).
date_default_timezone_set('Europe/Paris');
